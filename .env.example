# Copy this to .env and fill in your keys.
# NEVER commit .env — it is gitignored.

# OpenAI — used by Vision agent (GPT-4o) and Memory agent (embeddings)
OPENAI_API_KEY=sk-...

# Anthropic — used by Search agent (Claude Sonnet) and Fusion
ANTHROPIC_API_KEY=sk-ant-...

# Tavily — used by Search agent for live web results
TAVILY_API_KEY=tvly-...

# LangSmith — optional but strongly recommended for tracing
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=lens-os-phase0

# SQLite DB path (defaults to lens_memory.db in the project root)
# LENS_DB_PATH=lens_memory.db

# Copy this to .env and fill in your keys.
# NEVER commit .env — it is gitignored.

# Google Gemini — used by all agents (Vision, Memory, Search, Fusion)
GOOGLE_API_KEY=AIza...

# Tavily — used by Search agent for live web results
TAVILY_API_KEY=tvly-...

# LangSmith — optional, for tracing
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=lens-os-phase0
